<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
    <!-- Postgres EF Core provider: the AppDbContext maps MassTransit's own transactional outbox entities. -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Src\RCommon.MassTransit\RCommon.MassTransit.csproj" />
    <!-- Recipe 2b wraps MassTransit's NATIVE EF Core bus outbox via UseBrokerOutbox<TDbContext>. -->
    <ProjectReference Include="..\..\..\Src\RCommon.MassTransit.Outbox\RCommon.MassTransit.Outbox.csproj" />
    <!-- AppDbContext derives from RCommonDbContext (RCommon's EF Core datastore integration). -->
    <ProjectReference Include="..\..\..\Src\RCommon.EfCore\RCommon.EFCore.csproj" />
  </ItemGroup>

</Project>
