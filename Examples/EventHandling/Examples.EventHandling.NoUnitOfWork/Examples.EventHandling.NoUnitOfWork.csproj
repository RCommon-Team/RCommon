<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
    <!-- InMemory is only used by the optional standalone-outbox demonstration; the primary
         direct-publish escape hatch needs no persistence provider at all. -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <!-- RCommon.EFCore is only referenced for the optional standalone-outbox demonstration.
         The primary direct-publish escape hatch depends solely on RCommon.Core. -->
    <ProjectReference Include="..\..\..\Src\RCommon.EfCore\RCommon.EFCore.csproj" />
  </ItemGroup>

</Project>
